---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Nuestra Empresa | Gamma Médica">
  <Header />

  <main class="nosotros-page">
    <!-- Modern Hero Section -->
    <section class="premium-hero">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <h1 class="hero-title">
          NUESTRA <span class="text-gradient">EMPRESA</span>
        </h1>
        <p class="hero-subtitle">
          Innovación y precisión al servicio de la salud ocupacional y clínica
          en Lima y Callao.
        </p>
      </div>
    </section>

    <!-- Glassmorphism About Section -->
    <section class="about-section container">
      <div class="glass-card about-card">
        <div class="about-text">
          <h2 class="section-heading">Líderes en Salud Ocupacional</h2>
          <p class="lead-text">
            Pioneros en el sector Callao desde el año 2005.
          </p>
          <div class="text-content">
            <p>
              Somos una empresa innovadora dedicada a brindar servicios de salud
              integral. Nuestro servicio está estrictamente acreditado por
              DIGESA, cumpliendo la Ley N° 29783. Nos caracterizamos por brindar
              resultados confiables, oportunos, rápidos y 100% seguros.
            </p>
            <p>
              Contamos con un experto staff de profesionales médicos, tecnología
              de vanguardia y modernas instalaciones diseñadas para el confort
              total de los pacientes.
            </p>
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-number">+15</span>
              <span class="stat-label">Años de Excelencia</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">100%</span>
              <span class="stat-label">Acreditados DIGESA</span>
            </div>
          </div>
        </div>
        <div class="about-image-wrapper">
          <img
            src="/images/nosotros-1.webp"
            alt="Instalaciones de Gamma Médica"
            class="modern-img"
          />
        </div>
      </div>
    </section>

    <!-- Cards Misión y Visión -->
    <section class="mission-vision-section container">
      <div class="mv-grid">
        <div class="premium-card blue-card">
          <div class="card-header">
            <div class="card-icon">🎯</div>
            <h3>Nuestra Misión</h3>
          </div>
          <p>
            Prestar servicios integrales excepcionales en seguridad y salud en
            el trabajo. Aliviamos el dolor y contribuimos activamente al cuidado
            del bienestar humano. Operamos con total responsabilidad social,
            garantizando atención cálida y segura gracias a nuestro equipamiento
            de vanguardia.
          </p>
        </div>

        <div class="premium-card green-card">
          <div class="card-header">
            <div class="card-icon">👁️</div>
            <h3>Nuestra Visión</h3>
          </div>
          <p>
            Ser la institución médica líder y referente a nivel nacional e
            internacional. Buscamos posicionarnos por nuestra estricta
            responsabilidad social, la bioseguridad inquebrantable de nuestros
            protocolos y una calidad insuperable en la gestión de servicios de
            salud en el trabajo.
          </p>
        </div>
      </div>
    </section>

    <!-- Filosofía y Políticas -->
    <section class="philosophy-section">
      <div class="container philosophy-grid">
        <!-- Text Content -->
        <div class="philosophy-text">
          <h2 class="section-heading">Filosofía & Calidad</h2>
          <p class="section-description">
            Principios que rigen nuestro día a día y aseguran el éxito en la
            atención al paciente.
          </p>

          <div class="feature-block">
            <div class="feature-icon green-icon">✦</div>
            <div class="feature-content">
              <h4>Nuestra Filosofía</h4>
              <p>
                Ofrecemos un sitio próspero para el desarrollo profesional y
                personal de nuestros colaboradores. Fomentamos valores éticos
                irrompibles: honestidad, respeto absoluto, puntualidad y calidez
                en cada interacción.
              </p>
            </div>
          </div>

          <div class="feature-block">
            <div class="feature-icon blue-icon">✦</div>
            <div class="feature-content">
              <h4>Políticas de Calidad</h4>
              <p>
                Nuestro compromiso supremo es el bienestar íntegro del paciente.
                Garantizamos alta confianza mediante atención cordial en
                ambientes saludables, buscando la perfección diaria para
                potenciar nuestro servicio.
              </p>
            </div>
          </div>
        </div>

        <!-- Collage / Visuals -->
        <div class="philosophy-visual">
          <img
            src="/images/nosotros-2.webp"
            alt="Filosofía y Calidad de Gamma Médica"
            class="modern-img"
          />
          <div class="floating-badge">
            <span class="badge-icon">✓</span>
            <span class="badge-text">Certificación ISO / DIGESA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Nuestras Áreas - Collage -->
    <section class="areas-section">
      <div class="container">
        <div class="areas-header">
          <h2 class="section-heading">Nuestras <span class="text-gradient">Áreas</span></h2>
          <p class="section-description">Espacios diseñados para garantizar la mejor atención y comodidad en cada etapa del proceso médico.</p>
        </div>

        <div class="areas-collage">
          <div class="area-item area-large">
            <img src="/images/recepcion.webp" alt="Recepción" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Recepción</span>
            </div>
          </div>

          <div class="area-item">
            <img src="/images/laboratorio.webp" alt="Laboratorio" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Laboratorio</span>
            </div>
          </div>

          <div class="area-item">
            <img src="/images/triaje.webp" alt="Triaje" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Triaje</span>
            </div>
          </div>

          <div class="area-item">
            <img src="/images/audiometria.webp" alt="Audiometría" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Audiometría</span>
            </div>
          </div>

          <div class="area-item">
            <img src="/images/EKG.webp" alt="Electrocardiograma" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Electrocardiograma</span>
            </div>
          </div>

          <div class="area-item">
            <img src="/images/odontologia.webp" alt="Odontología" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Odontología</span>
            </div>
          </div>

          <div class="area-item area-large">
            <img src="/images/psicologia.webp" alt="Psicología" class="area-img" loading="lazy" />
            <div class="area-overlay">
              <span class="area-name">Psicología</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Base Page Styling */
  .nosotros-page {
    background-color: #f8fafc;
    padding-bottom: 5rem;
  }

  /* Ultra Modern Hero con imagen de fondo */
  .premium-hero {
    position: relative;
    padding: 10rem 2rem 8rem;
    background-image: url('/images/nosotros-1.webp');
    background-size: cover;
    background-position: center;
    background-color: #0b1a3d;
    overflow: hidden;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(8, 15, 34, 0.55) 0%, rgba(8, 15, 34, 0.85) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    color: #ffffff;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.5px;
  }

  .text-gradient {
    background: linear-gradient(135deg, #38bdf8, #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    color: #cbd5e1;
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 600px;
  }

  /* Glassmorphism About Section */
  .about-section {
    margin-top: 4rem;
    position: relative;
    z-index: 10;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 20px;
    padding: 4rem;
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-heading {
    font-size: 2.25rem;
    color: #0f172a;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .lead-text {
    font-size: 1.15rem;
    color: #2563eb;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .text-content p {
    color: #475569;
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .stats-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f172a;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: #64748b;
    font-weight: 600;
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .about-image-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
  }

  .modern-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Misión / Visión Section */
  .mission-vision-section {
    padding: 5rem 1rem 3rem;
  }

  .mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .premium-card {
    padding: 3rem;
    border-radius: 20px;
    color: white;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .premium-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding-bottom: 1.5rem;
  }

  .card-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .premium-card h3 {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
  }

  .premium-card p {
    font-size: 1.05rem;
    line-height: 1.7;
    opacity: 0.95;
    margin: 0;
  }

  .blue-card {
    background: linear-gradient(
      135deg,
      rgba(30, 58, 138, 0.55),
      rgba(15, 23, 42, 0.7)
    );
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .green-card {
    background: linear-gradient(
      135deg,
      rgba(5, 150, 105, 0.55),
      rgba(6, 78, 59, 0.7)
    );
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  /* Philosophy Section */
  .philosophy-section {
    padding: 5rem 1rem;
    background-color: #ffffff;
    border-top: 1px solid #f1f5f9;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-description {
    color: #64748b;
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .feature-block {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    background: #f8fafc;
    padding: 1.5rem;
    border-radius: 16px;
    border: 1px solid #f1f5f9;
    transition: background 0.3s ease;
  }

  .feature-block:hover {
    background: #ffffff;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
  }

  .feature-icon {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: white;
    flex-shrink: 0;
  }

  .green-icon {
    background: #10b981;
  }
  .blue-icon {
    background: #3b82f6;
  }

  .feature-content h4 {
    font-size: 1.25rem;
    color: #0f172a;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .feature-content p {
    color: #475569;
    line-height: 1.6;
    margin: 0;
    font-size: 0.95rem;
  }

  .philosophy-visual {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .floating-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: white;
    padding: 0.75rem 1.25rem;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 3;
  }

  .badge-icon {
    background: #e0e7ff;
    color: #4f46e5;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.8rem;
  }

  .badge-text {
    font-weight: 700;
    color: #1e293b;
    font-size: 0.9rem;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .glass-card {
      grid-template-columns: 1fr;
      padding: 3rem;
      gap: 3rem;
    }
    .philosophy-grid {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }
    .mv-grid,
    .philosophy-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .stats-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .premium-hero {
      padding: 8rem 1rem 10rem;
    }
    .glass-card {
      padding: 2rem;
    }
    .floating-badge {
      left: 10px;
      bottom: 10px;
      padding: 0.5rem 1rem;
    }
  }
</style>

<style is:global>
  /* === Nuestras Áreas - Collage Section === */
  .areas-section {
    padding: 5rem 1rem;
    background: linear-gradient(180deg, #ffffff 0%, #f1f5f9 100%);
    border-top: 1px solid #e2e8f0;
  }

  .areas-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .areas-header .section-heading {
    font-size: 2.25rem;
    margin-bottom: 1rem;
  }

  .areas-header .section-description {
    max-width: 600px;
    margin: 0 auto;
  }

  .areas-collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .area-item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .area-item:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 15px 35px rgba(23, 84, 207, 0.2);
    z-index: 2;
  }

  .area-large {
    grid-column: span 2;
    aspect-ratio: 16 / 7;
  }

  .area-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .area-item:hover .area-img {
    transform: scale(1.08);
  }

  .area-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(8, 15, 34, 0.75) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.5rem;
    transition: background 0.3s ease;
  }

  .area-item:hover .area-overlay {
    background: linear-gradient(180deg, transparent 20%, rgba(23, 84, 207, 0.7) 100%);
  }

  .area-name {
    color: #ffffff;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    transform: translateY(0);
    transition: transform 0.3s ease;
  }

  .area-item:hover .area-name {
    transform: translateY(-4px);
  }

  @media (max-width: 768px) {
    .areas-collage {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .area-large {
      grid-column: span 2;
      aspect-ratio: 16 / 9;
    }
    .area-name {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .areas-collage {
      grid-template-columns: 1fr;
    }
    .area-large {
      grid-column: span 1;
      aspect-ratio: 4 / 3;
    }
  }
</style>
