---
// src/components/BenefitsCards.astro
---

<section class="benefits-wrapper container">
  <div class="benefits-box">
    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="icon-circle"><img src="/images/equipo_profesional.webp" alt="Equipo Profesional" /></div>
        <h3>Equipo Profesional</h3>
        <p>Médicos y tecnólogos altamente calificados y certificados listos para brindarte la mejor atención.</p>
      </div>
      
      <div class="benefit-card">
        <div class="icon-circle"><img src="/images/servicio_rapido.webp" alt="Servicio Rápido y Seguro" /></div>
        <h3>Servicio Rápido y Seguro</h3>
        <p>Resultados online en tiempo récord bajo estrictos protocolos de confidencialidad.</p>
      </div>
      
      <div class="benefit-card">
        <div class="icon-circle"><img src="/images/tec.webp" alt="Tecnología de Vanguardia" /></div>
        <h3>Tecnología de Vanguardia</h3>
        <p>Equipos de última generación que garantizan análisis clínicos con precisión milimétrica.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .benefits-wrapper {
    margin-top: 2rem; /* Separación del area superior para no superponerse */
    position: relative;
    z-index: 10;
    margin-bottom: 6rem;
  }

  .benefits-box {
    max-width: 1250px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(248, 250, 252, 0.95), rgba(241, 245, 249, 0.9));
    border-radius: 24px;
    box-shadow: 0 20px 45px rgba(13, 72, 174, 0.309);
    padding: 4rem 2rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .benefit-card {
    background: var(--color-white);
    padding: 3rem 2rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--color-primary);
  }

  .benefit-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-hover);
    border-top-color: var(--color-accent);
  }

  .icon-circle {
    width: 105px;
    height: 105px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .icon-circle img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-bottom: 1rem;
  }

  p {
    color: var(--color-text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
</style>
