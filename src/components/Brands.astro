---
// src/components/Brands.astro

const brands = [
  { name: 'Adecco', src: '/images/Adecco.webp' },
  { name: 'Scharff', src: '/images/SCHARFF_logo_by_Yanina-Arabena_Guillermo-Vizzari_01-768x467-1.webp' },
  { name: 'SIMA', src: '/images/SIMA-1024x398.webp' },
  { name: 'Deprodeca', src: '/images/deprodeca-sac-1200-300x148-1.webp' },
  { name: 'INGEMMET', src: '/images/layout_set_logo.webp' },
  { name: 'Empresa', src: '/images/descarga.webp' },
  { name: 'Cliente', src: '/images/0.webp' },
  { name: 'Cliente 2', src: '/images/0-1.webp' }
];

// Multiplicamos para el efecto de scroll infinito
const marqueeBrands = [...brands, ...brands, ...brands];
---

<section class="brands-section">
  <div class="container">
    <div class="brands-header">
      <h3 class="brands-title">Empresas que confían en nosotros</h3>
      <div class="brands-line"></div>
    </div>
    
    <div class="marquee-container">
      <div class="marquee-track">
        {marqueeBrands.map((brand) => (
          <div class="brand-logo">
            <img src={brand.src} alt={`Logo de ${brand.name}`} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .brands-section {
    padding: 4rem 0;
    background-color: #ffffff; /* Fondo blanco puro para coincidir con las imágenes */
    border-top: 1px solid var(--color-border);
  }

  .brands-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .brands-title {
    font-size: 1.5rem;
    color: var(--color-text-main);
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .brands-line {
    width: 60px;
    height: 4px;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 2px;
  }

  .marquee-container {
    max-width: 100%;
    overflow: hidden;
    position: relative;
    /* Difuminado a los bordes para un efecto premium */
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: scrollBrands 30s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  .brand-logo {
    width: 150px; /* Tamaño estandarizado */
    height: 80px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.3s ease;
  }

  .brand-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  @keyframes scrollBrands {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Traduce el equivalente a 1/3 del ancho (porque triplicamos el array) */
      transform: translateX(-33.3333%);
    }
  }

  @media (max-width: 768px) {
    .brand-logo {
      width: 120px;
    }
    .marquee-track {
      gap: 2.5rem;
    }
  }
</style>
